{
  "version": 3,
  "configurePresets": [
    {
      "name": "win-msvc-debug",
      "displayName": "Windows x64 Debug",
      "description": "使用 MSVC 编译器和 Ninja 构建",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/${presetName}",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "toolset": {
        "value": "host=x64",
        "strategy": "external"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_MAKE_PROGRAM": "D:/Ninja/ninja.exe"
      }
    }
  ]
}
